    "dev": "tsup --watch"
  },
  "dependencies": {
    "@trillink/protocol": "workspace:*",
    "@trillink/sdk": "workspace:*",
    "ggwave": "^0.4.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.3"
  }
